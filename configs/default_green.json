{
  "dataset": {
    "step_size": 0.00390625,
    "n_points_per_line": 129,
    "samples_per_line": 50,
    "validation_samples_per_line": 10,
    "validation_sampler_mode": "backward",
    "scale_length": [
      0.05,
      0.25
