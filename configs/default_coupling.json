{
  "dataset": {
    "step_size": 0.0078125,
    "n_points_per_line": 129,
    "samples_per_line": 50,
    "scale_length": [
      0.05,
      0.25
    ],
    "deterministic": true,
    "sampler_mode": "backward",
    "use_operator_learning": true,
    "training_path": "data/Sinusoidal_Diffusion_Only/fold0/train",
    "validation_path": "data/Sinusoidal_Diffusion_Only/fold0/valid",
    "test_path": "data/Sinusoidal_Diffusion_Only/fold0/valid",
    "coefficient_functions_path": null,
    "dtype": "float64"
  },
  "terminal": {
    "width": 305
  },
  "coupling_model": {
    "hidden_dim": 256,
    "depth": 4,
    "activation": "rational",
    "use_bias": true,
    "dropout": 0.0,
    "branch_input_dim": 129,
    "trunk_input_dim": 2,
    "dtype": "float64",
    "balance_projection": "smooth_mask",
    "smooth_mask_normalize": true,
    "smooth_mask_eps": 1e-12,
    "smooth_mask_power": 1.0,
    "smooth_mask_diff_power": 1.0,
    "smooth_mask_diff_power_trainable": true,
    "smooth_mask_diff_power_min": 0.25,
    "smooth_mask_diff_power_max": 2.0,
    "source_stencil_lift": {
      "enabled": false,
      "encoder_type": "mlp",
      "coefficient_normalization": "rms",
      "coefficient_tanh_beta": 1.0,
      "hidden_dim": 32,
      "depth": 2,
      "activation": "gelu",
      "use_bias": true,
      "dropout": 0.05,
      "use_g_normalization": true,
      "eps": 1e-12
    }
  },
  "coupling_training": {
    "batch_size": 200,
    "log_interval": 1,
    "device": "cuda:1",
    "losses": {
      "l2_consistency": {
        "enabled": false,
        "weight": 1.0
      },
      "energy_consistency": {
        "enabled": true,
        "weight": 1.0
      },
      "cross_consistency": {
        "enabled": false,
        "weight": 1.0
      }
    },
    "integration_rule": "trapezoid",
    "epochs": 3000,
    "learning_rate": 0.002,
    "source_stencil_lift_learning_rate": null,
    "weight_decay": 0.01,
    "source_stencil_lift_weight_decay": null,
    "gradient_clip_max_norm": 1.0,
    "use_lr_schedule": true,
    "warmup_epochs": 3,
    "min_lr": 1e-5,
    "periodic_checkpoint": {
      "enabled": true,
      "every_epochs": 200
    },
    "best_rel_sol_checkpoint": {
      "enabled": true
    },
    "compile": {
      "enabled": true
    }
  },
  "pipeline": {
    "run_green": false,
    "run_coupling": true,
    "green_pretrained_path": "checkpoints/Sinusoidal_Diffusion_Only/green/backward/model.safetensors",
    "coupling_pretrained_path": null
  }
}
