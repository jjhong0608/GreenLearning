{
  "dataset": {
    "step_size": 0.0078125,
    "n_points_per_line": 129,
    "samples_per_line": 50,
    "scale_length": [
      0.05,
      0.25
    ],
    "deterministic": true,
    "sampler_mode": "backward",
    "use_operator_learning": true,
    "training_path": "data/5_fold_test_diffusion/fold0/train",
    "validation_path": "data/5_fold_test_diffusion/fold0/valid",
    "test_path": "data/5_fold_test_diffusion/fold0/valid",
    "dtype": "float64"
  },
  "coupling_model": {
    "hidden_dim": 128,
    "depth": 4,
    "activation": "rational",
    "use_bias": true,
    "dropout": 0.0,
    "branch_input_dim": 129,
    "trunk_input_dim": 2,
    "trunk_fourier": {
      "enabled": true,
      "frequencies": [
        3.141592653589793,
        6.283185307179586,
        12.566370614359172,
        25.132741228718345
      ]
    },
    "fusion": {
      "type": "gated_attention",
      "gated_attention": {
        "activation": "rational",
        "use_bias": true,
        "dropout": 0.0
      }
    },
    "line_encoder": {
      "type": "cnn1d",
      "in_channels": 3,
      "include_position": true,
      "include_boundary_distance": true,
      "conv_channels": [16, 32],
      "kernel_size": 3,
      "dilations": [1, 2],
      "pooling": "meanmax",
      "activation": "rational",
      "mlp_head": {
        "depth": 2,
        "hidden_dim": 128,
        "activation": "rational",
        "use_bias": true,
        "dropout": 0.0
      }
    },
    "dtype": "float64"
  },
  "coupling_training": {
    "batch_size": 200,
    "log_interval": 1,
    "device": "cuda:1",
    "losses": {
      "l2_consistency": {
        "enabled": true,
        "weight": 1.0,
        "weight_mode": "manual"
      },
      "flux_consistency": {
        "enabled": true,
        "weight": 1.0,
        "weight_mode": "auto_operator"
      },
      "cross_consistency": {
        "enabled": true,
        "weight": 1.0,
        "weight_mode": "auto_operator"
      }
    },
    "integration_rule": "trapezoid",
    "epochs": 3000,
    "learning_rate": 0.001,
    "use_lr_schedule": true,
    "warmup_epochs": 0,
    "min_lr": 1e-10,
    "periodic_checkpoint": {
      "enabled": true,
      "every_epochs": 200
    },
    "best_rel_sol_checkpoint": {
      "enabled": true
    },
    "compile": {
      "enabled": true
    }
  },
  "pipeline": {
    "run_green": false,
    "run_coupling": true,
    "green_pretrained_path": "checkpoints/test_diffusion/green/backward/model.safetensors",
    "coupling_pretrained_path": null
  }
}
