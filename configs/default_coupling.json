{
  "dataset": {
    "step_size": 0.0078125,
    "n_points_per_line": 129,
    "samples_per_line": 50,
    "scale_length": [
      0.05,
      0.25
    ],
    "deterministic": true,
    "sampler_mode": "backward",
    "use_operator_learning": true,
    "training_path": "data/5_fold_test_diffusion/fold0/train",
    "validation_path": "data/5_fold_test_diffusion/fold0/valid",
    "test_path": "data/5_fold_test_diffusion/fold0/valid",
    "dtype": "float64"
  },
  "coupling_model": {
    "hidden_dim": 256,
    "depth": 4,
    "activation": "rational",
    "use_bias": true,
    "dropout": 0.0,
    "branch_input_dim": 129,
    "trunk_input_dim": 2,
    "dtype": "float64",
    "coupler": {
      "enabled": true,
      "type": "five_stencil_stencil_mlp",
      "hidden_channels": 64,
      "depth": 2,
      "activation": "gelu",
      "dropout": 0.0,
      "residual_scale_init": 0.05,
      "padding": "replicate",
      "eps": 1e-12
    }
  },
  "coupling_training": {
    "batch_size": 200,
    "log_interval": 1,
    "device": "cuda:1",
    "losses": {
      "l2_consistency": {
        "enabled": false,
        "weight": 1.0
      },
      "energy_consistency": {
        "enabled": true,
        "weight": 1.0
      },
      "cross_consistency": {
        "enabled": false,
        "weight": 1.0
      }
    },
    "hybrid_detach": {
      "enabled": false,
      "projected_energy_weight": 1.0,
      "coupled_energy_weight": 0.3,
      "detach_coupler_input": true
    },
    "stage2": {
      "enabled": true,
      "checkpoint_path": "checkpoints/test_diffusion/coupling/with_detached_hybrid_loss/coupling_model.safetensors",
      "freeze_main": true,
      "train_coupler_only": true,
      "coupled_energy_weight": 1.0,
      "lr": 0.001,
      "weight_decay": 0.001,
      "epochs": 1000,
      "early_stopping": false,
      "log_relative_improvement": true,
      "log_delta_norm_ratio": true
    },
    "integration_rule": "trapezoid",
    "epochs": 3000,
    "learning_rate": 0.001,
    "use_lr_schedule": true,
    "warmup_epochs": 0,
    "min_lr": 1e-10,
    "periodic_checkpoint": {
      "enabled": true,
      "every_epochs": 200
    },
    "best_rel_sol_checkpoint": {
      "enabled": true
    },
    "compile": {
      "enabled": true
    }
  },
  "pipeline": {
    "run_green": false,
    "run_coupling": true,
    "green_pretrained_path": "checkpoints/test_diffusion/green/backward/model.safetensors",
    "coupling_pretrained_path": null
  }
}
