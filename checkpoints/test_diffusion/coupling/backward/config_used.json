{
  "dataset": {
    "step_size": 0.0078125,
    "n_points_per_line": 129,
    "samples_per_line": 50,
    "scale_length": [
      0.05,
      0.25
    ],
    "deterministic": true,
    "sampler_mode": "backward",
    "use_operator_learning": true,
    "training_path": "data/5_fold_test_diffusion/fold0/train",
    "validation_path": "data/5_fold_test_diffusion/fold0/valid",
    "test_path": "data/5_fold_test_diffusion/fold0/valid",
    "dtype": "float64"
  },
  "coupling_model": {
    "hidden_dim": 128,
    "depth": 4,
    "activation": "rational",
    "use_bias": true,
    "dropout": 0.0,
    "branch_input_dim": 129,
    "trunk_input_dim": 2,
    "dtype": "float64"
  },
  "coupling_training": {
    "batch_size": 200,
    "log_interval": 1,
    "device": "cuda:1",
    "lambda_consistency": 1.0,
    "flux_consistency_enabled": true,
    "lambda_flux_consistency": 0.01,
    "integration_rule": "trapezoid",
    "epochs": 3000,
    "learning_rate": 0.001,
    "use_lr_schedule": true,
    "warmup_epochs": 0,
    "min_lr": 1e-10,
    "periodic_checkpoint": {
      "enabled": true,
      "every_epochs": 200
    },
    "best_rel_sol_checkpoint": {
      "enabled": true
    },
    "compile": {
      "enabled": true
    }
  },
  "pipeline": {
    "run_green": false,
    "run_coupling": true,
    "green_pretrained_path": "checkpoints/test_diffusion/green/backward/model.safetensors",
    "coupling_pretrained_path": null
  }
}
